{
  "version": 2,
  "framework": "nextjs",
  "buildCommand": "npx prisma generate && npx next build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "git": {
    "deploymentEnabled": {
      "main": true,
      "develop": true
    }
  },
  "env": {
    "NEXT_TELEMETRY_DISABLED": "1"
  }
}
