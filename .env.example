# Database (Vercel Postgres sets POSTGRES_PRISMA_URL automatically)
# For local dev, set this to your local/remote Postgres URL
POSTGRES_PRISMA_URL="postgresql://postgres:[password]@host:5432/db?sslmode=require"

# NextAuth — auto-detects URL from request headers
# Set AUTH_SECRET via: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-random-string"

# Razorpay
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""
RAZORPAY_PRO_PLAN_ID=""
RAZORPAY_BUSINESS_PLAN_ID=""

# Supabase Realtime
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Sarvam AI (Indian language features — leave empty to skip)
SARVAM_API_KEY=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
